-- FUNCTIONS
local function parseTable(t, d)
    d = d or 0; if type(t) ~= "table" or d > 4 then return type(t) == "string" and '"'..t..'"' or tostring(t) end
    local res, i = "{", 0; for k, v in pairs(t) do i = i + 1; if i > 15 then res = res .. "... " break end; res = res .. '["'..tostring(k)..'"] = ' .. parseTable(v, d + 1) .. ", " end
    return res .. "}"
end

local function getSafePath(obj)
    local p = ""; pcall(function() local t = obj; while t and t ~= game do local n = tostring(t.Name); p = (n:match("[%s%W]") and '["'..n..'"]' or n) .. (p ~= "" and "." .. p or ""); t = t.Parent end end)
    return p ~= "" and "game." .. p:gsub("%.%[", "[") or "game.NilObject"
end

local function updateRedList()
    for _, v in pairs(RedListScroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for path, data in pairs(ManualBannedPaths) do
        local b = Instance.new("TextButton", RedListScroll)
        b.Size = UDim2.new(1, -6, 0, 25); b.BackgroundColor3 = Color3.fromRGB(80, 30, 30); b.Text = path:sub(-15); b.TextColor3 = Color3.new(1,1,1); b.Font = Enum.Font.SourceSans; b.TextSize = 10; b.BorderSizePixel = 0
        b.MouseButton1Click:Connect(function() Details.Text = "MANUALLY BLOCKED PATH:\n" .. path end)
    end
end

local function addLog(rem, args, isSelf, typeLabel)
    if (typeLabel == "FS" and not spyFS) or (typeLabel == "FC" and not spyFC) or (typeLabel == "IS" and not spyIS) then return end
    local eventPath = getSafePath(rem)
    if ManualBannedPaths[eventPath] then return end
    local argStrings = {}
    for _, v in pairs(args) do pcall(function() table.insert(argStrings, (typeof(v) == "Instance" and getSafePath(v) or parseTable(v))) end) end
    local finalArgs = table.concat(argStrings, ", "); local sig = eventPath .. finalArgs
    if isSelf then
        if selfMode then if PathFilter["MY_P_"..eventPath] then return end; PathFilter["MY_P_"..eventPath] = true else if PathFilter["MY_S_"..sig] then return end; PathFilter["MY_S_"..sig] = true end
    else
        if controlMode then if PathFilter["G_P_"..eventPath] then return end; PathFilter["G_P_"..eventPath] = true end
        if PathFilter["G_S_"..sig] then return end
        if not controlMode and antiSpam then
            if BannedPaths[eventPath] then return end
            if (tick() - (AntiSpamCooldowns[eventPath] or 0)) < 0.6 then AntiSpamCounts[eventPath] = (AntiSpamCounts[eventPath] or 0) + 1
                if AntiSpamCounts[eventPath] >= 3 then BannedPaths[eventPath] = true return end; return
            else AntiSpamCounts[eventPath] = 0 end; AntiSpamCooldowns[eventPath] = tick()
        end; PathFilter["G_S_"..sig] = true
    end
    local method = (typeLabel == "IS" and "InvokeServer" or (typeLabel == "FC" and "FireClient" or "FireServer"))
    local data = {guid = generateGUID(), name = tostring(rem.Name), type = typeLabel, isSelf = isSelf, fullText = string.format("Type: %s\nPath: %s\n\nArgs: %s\n\nScript: %s:%s(%s)", typeLabel, eventPath, finalArgs, eventPath, method, finalArgs)}
    if isSelf then table.insert(MainMemory, 1, data) else local idx = 1; for i, v in ipairs(MainMemory) do if not v.isSelf then break end; idx = i + 1 end; table.insert(MainMemory, idx, data) end
end

-- HOOK
local mt = getrawmetatable(game); local old = mt.__namecall; setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    local m = getnamecallmethod(); local a = {...}; local s = checkcaller()
    if m:lower() == "fireserver" then task.spawn(addLog, self, a, s, "FS")
    elseif m:lower() == "fireclient" then task.spawn(addLog, self, a, s, "FC")
    elseif m:lower() == "invokeserver" then task.spawn(addLog, self, a, s, "IS") end
    return old(self, ...)
end); setreadonly(mt, true)

