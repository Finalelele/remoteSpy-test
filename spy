local function getSafePath(obj)
    local path = ""
    local success = pcall(function()
        local temp = obj
        while temp and temp ~= game do
            local name = tostring(temp.Name)
            path = (name:match("[%s%W]") and '["'..name..'"]' or name) .. (path ~= "" and "." .. path or "")
            temp = temp.Parent
        end
    end)
    return success and "game." .. path:gsub("%.%[", "[") or "game.Unknown"
end

local function formatVal(v)
    if v == nil then return "nil" end
    local t = typeof(v)
    if t == "table" then
        local s = "{"
        local count = 0
        pcall(function()
            for k, val in pairs(v) do 
                count = count + 1
                s = s .. tostring(k) .. "=" .. (typeof(val) == "string" and '"'..val..'"' or tostring(val)) .. ", "
                if count > 5 or #s > 60 then s = s .. "..." break end
            end
        end)
        return s:gsub(", $", "") .. "}"
    elseif t == "Instance" then return getSafePath(v)
    elseif t == "string" then return '"'..v..'"'
    else return tostring(v) end
end

local function addLog(rem, args, isSelf)
    local name = tostring(rem.Name)
    -- СРАЗУ сохраняем путь в переменную, пока ивент еще жив
    local fullPath = getSafePath(rem) 
    
    if controlMode and pathHistory[fullPath] and not isSelf then return end

    local argTable = {}
    for i=1, 15 do 
        if args[i] == nil and i > 1 then break end
        table.insert(argTable, formatVal(args[i]))
    end
    local argStr = table.concat(argTable, ", ")
    
    -- Генерируем готовый текст для отображения заранее
    local logDetails = "Path: "..fullPath.."\n\nArgs: "..argStr.."\n\nScript: "..fullPath..":FireServer("..argStr..")"
    
    local uniqueKey = name .. "|" .. argStr
    
    -- Логика спам-фильтра
    if not isSelf then
        if not spamStats[fullPath] then spamStats[fullPath] = {count = 0, lastTime = 0, blocked = false} end
        local stat = spamStats[fullPath]
        if stat.blocked then return end
        
        local now = tick()
        local isSpamming = (now - stat.lastTime < 0.8)
        stat.lastTime = now; stat.count = stat.count + 1
        
        if stat.count > 10 then stat.blocked = true; return end
        
        if isSpamming then
            local b = Instance.new("TextButton", SpamFrame)
            b.Size = UDim2.new(1, 0, 0, 26); b.Text = name; b.ZIndex = 5; b.BorderSizePixel = 0
            b.BackgroundColor3 = Color3.fromRGB(70, 30, 30); b.TextColor3 = Color3.new(1, 1, 1)
            b.MouseButton1Click:Connect(function()
                if selectedData then selectedData.btn.BackgroundColor3 = selectedData.color end
                selectedData = {btn = b, color = Color3.fromRGB(70, 30, 30)}
                b.BackgroundColor3 = Color3.fromRGB(150, 50, 255)
                -- Используем заранее сохраненный текст
                Details.Text = logDetails 
            end)
            return
        end
    end

    if history[uniqueKey] and not isSelf then return end
    history[uniqueKey] = true
    pathHistory[fullPath] = true
    
    local b = Instance.new("TextButton", Scroll)
    b.Size = UDim2.new(1, 0, 0, 26); b.Text = (isSelf and "[S] " or "") .. name; b.ZIndex = 5; b.BorderSizePixel = 0
    local defCol = isSelf and Color3.fromRGB(30, 60, 30) or Color3.fromRGB(40, 40, 40)
    b.BackgroundColor3 = defCol; b.TextColor3 = Color3.new(1, 1, 1)
    
    b.MouseButton1Click:Connect(function()
        if selectedData then selectedData.btn.BackgroundColor3 = selectedData.color end
        selectedData = {btn = b, color = defCol}
        b.BackgroundColor3 = Color3.fromRGB(150, 50, 255)
        -- Используем заранее сохраненный текст, он не сломается после удаления ивента
        Details.Text = logDetails 
    end)
end

