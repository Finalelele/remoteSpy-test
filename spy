-- ПАРСЕР
local function parseTable(t, depth)
    depth = depth or 0
    if type(t) ~= "table" or depth > 4 then return type(t) == "string" and '"'..t..'"' or tostring(t) end
    local result, isArray, count, i = "{", true, 0, 0
    for k, v in pairs(t) do count = count + 1; if type(k) ~= "number" then isArray = false end end
    for k, v in pairs(t) do
        i = i + 1; if i > 15 then result = result .. "... " break end
        local val = parseTable(v, depth + 1)
        result = result .. (isArray and val or '["'..tostring(k)..'"] = ' .. val)
        if i < count then result = result .. ", " end
    end
    return result .. "}"
end

local function getSafePath(obj)
    local p = ""
    pcall(function()
        local t = obj
        while t and t ~= game do
            local n = tostring(t.Name); p = (n:match("[%s%W]") and '["'..n..'"]' or n) .. (p ~= "" and "." .. p or ""); t = t.Parent
        end
    end)
    return p ~= "" and "game." .. p:gsub("%.%[", "[") or "game.NilObject"
end

-- LOGIC
local function addLog(rem, args, isSelf, typeLabel)
    if (typeLabel == "FS" and not spyFS) or (typeLabel == "FC" and not spyFC) or (typeLabel == "IS" and not spyIS) then return end
    local eventPath = getSafePath(rem)
    local argStrings = {}
    for _, v in pairs(args) do pcall(function() table.insert(argStrings, (typeof(v) == "Instance" and getSafePath(v) or parseTable(v))) end) end
    local finalArgs = table.concat(argStrings, ", ")
    local sig = eventPath .. finalArgs
    
    if not controlMode and antiSpam and not isSelf then
        if BannedPaths[eventPath] then return end
        if PathFilter[sig] then return end
        local now = tick()
        local lastTime = AntiSpamCooldowns[eventPath] or 0
        if (now - lastTime) < 0.6 then
            AntiSpamCounts[eventPath] = (AntiSpamCounts[eventPath] or 0) + 1
            if AntiSpamCounts[eventPath] >= 3 then BannedPaths[eventPath] = true return end
            return 
        else AntiSpamCounts[eventPath] = 0 end
        AntiSpamCooldowns[eventPath] = now
    end

    local filterSig = controlMode and eventPath or sig
    if not isSelf and PathFilter[filterSig] then return end
    if isSelf and selfMode and PathFilter["S" .. filterSig] then return end
    
    PathFilter[isSelf and "S" .. filterSig or filterSig] = true
    local method = (typeLabel == "IS" and "InvokeServer" or (typeLabel == "FC" and "FireClient" or "FireServer"))
    
    table.insert(MainMemory, 1, {
        guid = generateGUID(),
        name = tostring(rem.Name), 
        type = typeLabel, 
        fullText = string.format("Type: %s\nPath: %s\n\nArgs: %s\n\nScript: %s:%s(%s)", typeLabel, eventPath, finalArgs, eventPath, method, finalArgs), 
        isSelf = isSelf
    })
end

-- HOOK
local mt = getrawmetatable(game); local old = mt.__namecall; setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    local m = getnamecallmethod(); local a = {...}; local s = checkcaller()
    if m == "FireServer" or m == "fireServer" then task.spawn(addLog, self, a, s, "FS")
    elseif m == "FireClient" or m == "fireClient" then task.spawn(addLog, self, a, s, "FC")
    elseif m == "InvokeServer" or m == "invokeServer" then task.spawn(addLog, self, a, s, "IS") end
    return old(self, ...)
end)
setreadonly(mt, true)

