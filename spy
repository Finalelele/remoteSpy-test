-- UNIVERSAL MEMORY BASE (TEXT-ONLY)
local textHistory = {} -- Хранит полные данные (Path + Args)
local pathDatabase = {} -- Хранит только пути для CONTROL: ON
local spamDatabase = {} -- Статистика для блокировки
local controlMode = true
local selectedBtn = nil

local function getSafePath(obj)
    local p = ""
    local success = pcall(function()
        local t = obj
        while t and t ~= game do
            local n = tostring(t.Name)
            p = (n:match("[%s%W]") and '["'..n..'"]' or n) .. (p ~= "" and "." .. p or "")
            t = t.Parent
        end
    end)
    return success and "game." .. p:gsub("%.%[", "[") or "game.UnknownObject"
end

local function addLog(rem, args, isSelf)
    -- ШАГ 1: Мгновенная конвертация в текст
    local eventName = tostring(rem.Name)
    local eventPath = getSafePath(rem)
    local argStrings = {}
    for _, v in pairs(args) do 
        pcall(function() 
            table.insert(argStrings, (typeof(v) == "Instance" and getSafePath(v) or (typeof(v) == "string" and '"'..v..'"' or tostring(v))))
        end)
    end
    local finalArgs = table.concat(argStrings, ", ")
    local fullLogText = "Path: "..eventPath.."\n\nArgs: "..finalArgs.."\n\nScript: "..eventPath..":FireServer("..finalArgs..")"
    
    local uniqueID = eventPath .. "|" .. finalArgs -- Уникальный ключ Path + Args
    local currentTime = tick()

    -- ШАГ 2: Проверка CONTROL: ON
    if controlMode and not isSelf then
        if pathDatabase[eventPath] then return end -- Если этот ПУТЬ уже был, игнорируем
    end

    -- ШАГ 3: Проверка Спама и Блокировки
    if not controlMode and not isSelf then
        if not spamDatabase[eventPath] then 
            spamDatabase[eventPath] = {lastTime = 0, count = 0, isBlocked = false} 
        end
        local data = spamDatabase[eventPath]
        
        if data.isBlocked then return end
        
        local isFast = (currentTime - data.lastTime < 0.8)
        data.lastTime = currentTime

        if isFast then
            data.count = data.count + 1
            if data.count > 15 then 
                data.isBlocked = true
                warn("[KRALLDEN]: Blocked spam from " .. eventName)
                return 
            end
            
            -- Кнопка в СПАМ лист
            local sb = Instance.new("TextButton", SpamFrame)
            sb.Size = UDim2.new(1, -6, 0, 28); sb.Text = eventName; sb.ZIndex = 100
            sb.BackgroundColor3 = Color3.fromRGB(60, 25, 25); sb.TextColor3 = Color3.new(1,1,1); sb.BorderSizePixel = 0
            sb.MouseButton1Click:Connect(function() Details.Text = fullLogText end)
            return
        end
    end

    -- ШАГ 4: Основное окно (Если ивент новый или медленный)
    if textHistory[uniqueID] and not isSelf then return end
    
    textHistory[uniqueID] = true
    pathDatabase[eventPath] = true

    local b = Instance.new("TextButton", Scroll)
    b.Size = UDim2.new(1, -6, 0, 30); b.Text = (isSelf and "[S] " or "") .. eventName; b.ZIndex = 100
    b.BackgroundColor3 = isSelf and Color3.fromRGB(35, 70, 35) or Color3.fromRGB(40, 40, 45)
    b.TextColor3 = Color3.new(1,1,1); b.BorderSizePixel = 0
    
    b.MouseButton1Click:Connect(function()
        if selectedBtn then selectedBtn.BackgroundColor3 = selectedBtn:GetAttribute("OldCol") end
        b:SetAttribute("OldCol", b.BackgroundColor3)
        selectedBtn = b; b.BackgroundColor3 = Color3.fromRGB(150, 50, 255)
        Details.Text = fullLogText
    end)
end

