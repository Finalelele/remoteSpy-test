local function addLog(rem, args, isSelf, typeLabel)
    if (typeLabel == "FS" and not spyFS) or (typeLabel == "FC" and not spyFC) or (typeLabel == "IS" and not spyIS) then return end
    local path = serialize(rem)
    if ManualBannedPaths[path] then return end
    
    local argStr = {}; for i, v in pairs(args) do table.insert(argStr, serialize(v)) end
    local finalArgs = table.concat(argStr, ", ")
    local logData = string.format("Type: %s\nPath: %s\nArgs: %s\n\nScript:\n%s:%s(%s)", typeLabel, path, finalArgs, path, (typeLabel == "IS" and "InvokeServer" or "FireServer"), finalArgs)

    if AntiSpamBtn.Text == "ANTI-SPAM: ON" then
        if tick() - (AntiSpamCooldowns[path] or 0) < 0.5 then
            AntiSpamCounts[path] = (AntiSpamCounts[path] or 0) + 1
            if AntiSpamCounts[path] > 5 then
                ManualBannedPaths[path] = {guid = generateGUID(), details = "AUTO-BANNED:\n" .. logData}; updateRedList(); return
            end
        else AntiSpamCounts[path] = 0 end
        AntiSpamCooldowns[path] = tick()
    end

    local data = {guid = generateGUID(), name = rem.Name, type = typeLabel, isSelf = isSelf, fullText = logData}
    table.insert(MainMemory, 1, data); if #MainMemory > 100 then table.remove(MainMemory) end
end

