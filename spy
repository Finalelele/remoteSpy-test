-- ПЕРЕХВАТ (CORE)
local function getSafePath(obj)
    local p = ""
    pcall(function()
        local t = obj
        while t and t ~= game do
            local n = tostring(t.Name); p = (n:match("[%s%W]") and '["'..n..'"]' or n) .. (p ~= "" and "." .. p or ""); t = t.Parent
        end
    end)
    return p ~= "" and "game." .. p:gsub("%.%[", "[") or "game.NilObject"
end

local function addLog(rem, args, isSelf, typeLabel)
    if typeLabel == "FS" and not spyFS then return end
    if typeLabel == "FC" and not spyFC then return end
    if typeLabel == "IS" and not spyIS then return end

    local eventPath = getSafePath(rem)
    local argStrings = {}
    for _, v in pairs(args) do pcall(function() table.insert(argStrings, (typeof(v) == "Instance" and getSafePath(v) or parseTable(v))) end) end
    local finalArgs = table.concat(argStrings, ", ")
    
    -- Фильтрация
    if isSelf then
        if selfMode then
            local sig = eventPath .. finalArgs; if PathFilter[sig] then return end; PathFilter[sig] = true
        end
    else
        if controlMode then
            if PathFilter[eventPath] then return end; PathFilter[eventPath] = true
        else
            local sig = tostring(rem.Name) .. finalArgs; if PathFilter[sig] then return end; PathFilter[sig] = true
        end
    end

    local method = (typeLabel == "IS" and "InvokeServer" or (typeLabel == "FC" and "FireClient" or "FireServer"))
    local fullText = string.format("Type: %s\nPath: %s\n\nArgs: %s\n\nScript: %s:%s(%s)", typeLabel, eventPath, finalArgs, eventPath, method, finalArgs)
    
    table.insert(MainMemory, {name = tostring(rem.Name), type = typeLabel, path = eventPath, fullText = fullText, isSelf = isSelf})
end

-- HOOKS
local mt = getrawmetatable(game); local old = mt.__namecall; setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    local m = getnamecallmethod()
    local a = {...}
    local s = checkcaller()
    
    if m == "FireServer" or m == "fireServer" then task.spawn(addLog, self, a, s, "FS")
    elseif m == "FireClient" or m == "fireClient" then task.spawn(addLog, self, a, s, "FC")
    elseif m == "InvokeServer" or m == "invokeServer" then task.spawn(addLog, self, a, s, "IS") end
    
    return old(self, ...)
end)
setreadonly(mt, true)

