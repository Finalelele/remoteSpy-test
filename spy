-- [[ СЕРИАЛИЗАТОР (БЕЗ ВЫРЕЗОК) ]] --
local function serialize(val, depth)
    depth = depth or 0
    local t = typeof(val)
    if t == "string" then return '"' .. val .. '"'
    elseif t == "number" or t == "boolean" then return tostring(val)
    elseif t == "Vector3" then return "Vector3.new(" .. tostring(val) .. ")"
    elseif t == "Vector2" then return "Vector2.new(" .. tostring(val) .. ")"
    elseif t == "CFrame" then return "CFrame.new(" .. tostring(val) .. ")"
    elseif t == "Color3" then return "Color3.new(" .. tostring(val) .. ")"
    elseif t == "Instance" then 
        local p = ""; pcall(function() 
            local o = val; while o and o ~= game do 
                local n = o.Name; p = (n:match("[%s%W]") and '["'..n..'"]' or n)..(p ~= "" and "."..p or ""); o = o.Parent 
            end 
        end)
        return p ~= "" and "game." .. p:gsub("%.%[", "[") or "nil"
    elseif t == "table" then
        if depth > 4 then return "{...}" end
        local s = "{"; local count = 0
        for k, v in pairs(val) do
            count = count + 1; if count > 20 then s = s .. "... " break end
            local key = type(k) == "string" and '["'..k..'"]' or "["..tostring(k).."]"
            s = s .. key .. " = " .. serialize(v, depth + 1) .. ", "
        end
        return count > 0 and s:sub(1, #s-2) .. "}" or "{}"
    end
    return "nil"
end

