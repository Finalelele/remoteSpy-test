local function parseTable(t, depth)
    depth = depth or 0; if type(t) ~= "table" or depth > 3 then return tostring(t) end
    local r = "{"; for k, v in pairs(t) do r = r .. tostring(k) .. "=" .. parseTable(v, depth+1) .. "," end
    return r .. "}"
end

local function addLog(rem, args, isSelf, typeLabel)
    if (typeLabel == "FS" and not spyFS) or (typeLabel == "IS" and not spyIS) then return end
    local path = "game." .. rem:GetFullName()
    local argStr = ""; for _, v in pairs(args) do argStr = argStr .. parseTable(v) .. ", " end
    local scriptStr = string.format("%s:%s(%s)", path, (typeLabel=="IS" and "InvokeServer" or "FireServer"), argStr)

    table.insert(MainMemory, 1, {
        guid = generateGUID(), name = rem.Name, type = typeLabel, isSelf = isSelf,
        fullText = "Type: "..typeLabel.."\nPath: "..path.."\nArgs: "..argStr.."\nScript: "..scriptStr,
        argsOnly = argStr, scriptOnly = scriptStr
    })
end

local mt = getrawmetatable(game); local old = mt.__namecall; setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    local m = getnamecallmethod(); local s = checkcaller()
    if m == "FireServer" or m == "InvokeServer" then task.spawn(addLog, self, {...}, s, m == "FireServer" and "FS" or "IS") end
    return old(self, ...)
end)

