-- Функции хелперы
local function getSafePath(obj)
    local success, result = pcall(function()
        local path = ""
        local temp = obj
        while temp and temp ~= game do
            local name = tostring(temp.Name)
            path = (name:match("[%s%W]") and '["'..name..'"]' or name) .. (path ~= "" and "." .. path or "")
            temp = temp.Parent
        end
        return "game." .. path:gsub("%.%[", "[")
    end)
    return success and result or "game.UnknownObject"
end

local function formatVal(v)
    local t = typeof(v)
    if t == "table" then
        return "{table}" -- Упростил для стабильности
    elseif t == "Instance" then
        return getSafePath(v)
    elseif t == "string" then
        return '"'..v..'"'
    end
    return tostring(v)
end

