-- LOGIC
local callCounts, lastTime, loggedKeys, blacklisted = {}, {}, {}, {}
local curArgs, curScript = "", ""

local function getSafePath(obj)
    local path = ""
    local success, err = pcall(function()
        local temp = obj
        while temp and temp ~= game do
            local name = temp.Name
            -- Если имя содержит пробелы или спецсимволы, оборачиваем в [""]
            if name:match("[%s%W]") then
                name = '["' .. name .. '"]'
                path = name .. (path ~= "" and "." .. path or "")
            else
                path = name .. (path ~= "" and "." .. path or "")
            end
            temp = temp.Parent
        end
    end)
    
    if path ~= "" then 
        -- Исправляем возможные двойные точки при использовании [""]
        path = path:gsub("%.%[", "[")
        return "game." .. path 
    end
    return "Unknown_Path"
end

local function formatVal(v)
    local t = typeof(v)
    if v == nil then return "nil" end
    if t == "table" then return "{table}"
    elseif t == "Instance" then return getSafePath(v)
    elseif t == "string" then return '"'..v..'"'
    else return tostring(v) end
end

local function addLog(rem, args, isSelf)
    local success, err = pcall(function()
        local name = rem.Name
        local argTable = {}
        for i=1, 10 do 
            local v = args[i]
            if v == nil and i > 1 then break end
            table.insert(argTable, formatVal(v))
        end
        local argStr = table.concat(argTable, ", ")
        local key = name .. "|" .. argStr
        
        if blacklisted[name] and not isSelf then return end
        
        local now = tick()
        local isSpam = lastTime[name] and (now - lastTime[name] < 0.8) 
        
        if not isSelf then
            callCounts[name] = (callCounts[name] or 0) + 1
            lastTime[name] = now
            if callCounts[name] > 10 then -- Лимит 10 как просил
                blacklisted[name] = true
                warn("[QuantumSpy] Remote " .. name .. " заблокирован из-за спама (>10 вызовов)")
                return 
            end
            if loggedKeys[key] then return end
        end
        
        loggedKeys[key] = true
        local target = (isSpam and not isSelf) and SpamFrame or Scroll
        
        local b = Instance.new("TextButton", target)
        b.Size = UDim2.new(1, 0, 0, 26)
        b.Text = (isSelf and "[S] " or "") .. name
        b.BackgroundColor3 = isSelf and Color3.fromRGB(30, 60, 30) or (isSpam and Color3.fromRGB(70, 30, 30) or Color3.fromRGB(40, 40, 40))
        b.TextColor3 = Color3.new(1, 1, 1)
        
        b.MouseButton1Click:Connect(function()
            local fullPath = getSafePath(rem)
            curArgs = argStr
            curScript = fullPath .. ":FireServer(" .. argStr .. ")"
            Details.Text = "Path: " .. fullPath .. "\n\nArgs: " .. argStr .. "\n\nScript: " .. curScript
        end)
    end)
    if not success then warn("[QS BUG v4.5]: " .. tostring(err)) end
end

CopyArgs.MouseButton1Click:Connect(function() setclipboard(curArgs) end)
CopyScript.MouseButton1Click:Connect(function() setclipboard(curScript) end)

local mt = getrawmetatable(game)
local old = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    if method == "FireServer" or method == "fireServer" then
        local args = {...}
        local isSelf = checkcaller()
        task.spawn(function() addLog(self, args, isSelf) end)
    end
    return old(self, ...)
end)
setreadonly(mt, true)
