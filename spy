-- LOGIC UTILS
local history = {} -- Для фильтра Уникальности (Имя + Аргументы)
local spamStats = {} -- Для фильтра Частоты (Путь)
local selectedData = nil

local function getSafePath(obj)
    local path = ""
    pcall(function()
        local temp = obj
        while temp and temp ~= game do
            local name = temp.Name
            path = (name:match("[%s%W]") and '["'..name..'"]' or name) .. (path ~= "" and "." .. path or "")
            temp = temp.Parent
        end
    end)
    return "game." .. path:gsub("%.%[", "[")
end

local function formatVal(v)
    if v == nil then return "nil" end
    local t = typeof(v)
    if t == "table" then return "{table}"
    elseif t == "Instance" then return getSafePath(v)
    elseif t == "string" then return '"'..v..'"'
    else return tostring(v) end
end

local function addLog(rem, args, isSelf)
    local name = rem.Name
    local fullPath = getSafePath(rem)
    
    -- Генерируем строку аргументов для проверки
    local argTable = {}
    for i=1, 15 do 
        if args[i] == nil and i > 1 then break end
        table.insert(argTable, formatVal(args[i]))
    end
    local argStr = table.concat(argTable, ", ")
    
    -- Ключи для фильтров
    local uniqueKey = name .. "|" .. argStr
    local pathKey = fullPath
    
    -- 1. СИСТЕМА СОРТИРОВКИ СПАМА (Путь)
    if not isSelf then
        if not spamStats[pathKey] then spamStats[pathKey] = {count = 0, lastTime = 0, blocked = false} end
        local stat = spamStats[pathKey]
        
        if stat.blocked then return end -- Полная блокировка после 10 вызовов
        
        local now = tick()
        local isSpamming = (now - stat.lastTime < 0.8)
        stat.lastTime = now
        stat.count = stat.count + 1
        
        if stat.count > 10 then
            stat.blocked = true
            warn("[QuantumSpy] BLOCKED: " .. pathKey)
            return
        end
        
        -- Если это спам по пути - отправляем в красный список
        if isSpamming then
            local b = Instance.new("TextButton", SpamFrame)
            b.Size = UDim2.new(1, 0, 0, 26); b.Text = name; b.ZIndex = 15
            b.BackgroundColor3 = Color3.fromRGB(70, 30, 30); b.TextColor3 = Color3.new(1, 1, 1)
            b.MouseButton1Click:Connect(function()
                if selectedData then selectedData.btn.BackgroundColor3 = selectedData.color end
                selectedData = {btn = b, color = Color3.fromRGB(70, 30, 30)}
                b.BackgroundColor3 = Color3.fromRGB(150, 50, 255)
                Details.Text = "Path: "..fullPath.."\n\nArgs: "..argStr.."\n\nScript: "..fullPath..":FireServer("..argStr..")"
            end)
            return -- Спам ивенты не идут в основной список
        end
    end

    -- 2. СИСТЕМА УНИКАЛЬНОСТИ (Имя + Аргументы)
    if history[uniqueKey] and not isSelf then return end
    history[uniqueKey] = true
    
    local b = Instance.new("TextButton", Scroll)
    b.Size = UDim2.new(1, 0, 0, 26); b.Text = (isSelf and "[S] " or "") .. name; b.ZIndex = 15
    local defCol = isSelf and Color3.fromRGB(30, 60, 30) or Color3.fromRGB(40, 40, 40)
    b.BackgroundColor3 = defCol; b.TextColor3 = Color3.new(1, 1, 1)
    
    b.MouseButton1Click:Connect(function()
        if selectedData then selectedData.btn.BackgroundColor3 = selectedData.color end
        selectedData = {btn = b, color = defCol}
        b.BackgroundColor3 = Color3.fromRGB(150, 50, 255)
        Details.Text = "Path: "..fullPath.."\n\nArgs: "..argStr.."\n\nScript: "..fullPath..":FireServer("..argStr..")"
    end)
end

CopyArgs.MouseButton1Click:Connect(function() setclipboard(Details.Text:match("Args: (.*)\n\nScript") or "") end)
CopyScript.MouseButton1Click:Connect(function() setclipboard(Details.Text:match("Script: (.*)") or "") end)

local mt = getrawmetatable(game)
local old = mt.__namecall
setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    if method == "FireServer" or method == "fireServer" then
        local args = {...}
        local isSelf = checkcaller()
        task.spawn(function() pcall(addLog, self, args, isSelf) end)
    end
    return old(self, ...)
end)
setreadonly(mt, true)
