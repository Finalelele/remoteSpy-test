-- ЛОГИКА UI
local function RebuildGUI()
    if not ContentFrame.Visible or #MainMemory == lastCount then return end
    lastCount = #MainMemory
    for _, child in pairs(Scroll:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
    for i, data in ipairs(MainMemory) do
        local b = Instance.new("TextButton", Scroll)
        b.Size = UDim2.new(1, -6, 0, 30); b.BorderSizePixel = 0
        b.Text = string.format("[%s]%s %s", data.type, (data.isSelf and " [S]" or ""), data.name)
        b.BackgroundColor3 = (currentSelectionID == i) and Color3.fromRGB(150, 50, 255) or (data.isSelf and Color3.fromRGB(35, 70, 35) or Color3.fromRGB(40, 40, 45))
        b.TextColor3 = Color3.new(1,1,1); b.LayoutOrder = -i -- Новые сверху
        b.MouseButton1Click:Connect(function()
            currentSelectionID = i; Details.Text = data.fullText
            for _, v in pairs(Scroll:GetChildren()) do if v:IsA("TextButton") then 
                v.BackgroundColor3 = (v.LayoutOrder == -i) and Color3.fromRGB(150, 50, 255) or (v.Text:find("%[S%]") and Color3.fromRGB(35, 70, 35) or Color3.fromRGB(40, 40, 45))
            end end
        end)
    end
end

