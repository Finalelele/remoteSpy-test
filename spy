local function getSafePath(obj)
    local path = ""
    pcall(function()
        local temp = obj
        while temp and temp ~= game do
            local name = temp.Name
            path = (name:match("[%s%W]") and '["'..name..'"]' or name) .. (path ~= "" and "." .. path or "")
            temp = temp.Parent
        end
    end)
    return "game." .. path:gsub("%.%[", "[")
end

local function formatVal(v)
    if v == nil then return "nil" end
    local t = typeof(v)
    if t == "table" then return "{table}"
    elseif t == "Instance" then return getSafePath(v)
    elseif t == "string" then return '"'..v..'"'
    else return tostring(v) end
end

local function addLog(rem, args, isSelf)
    local name = rem.Name
    if blacklisted[name] and not isSelf then return end
    
    local now = tick()
    local isSpam = lastTime[name] and (now - lastTime[name] < 0.8)
    
    if not isSelf then
        callCounts[name] = (callCounts[name] or 0) + 1
        lastTime[name] = now
        if callCounts[name] > 10 then 
            blacklisted[name] = true
            return 
        end
    end
    
    local argTable = {}
    for i=1, 10 do 
        if args[i] == nil and i > 1 then break end
        table.insert(argTable, formatVal(args[i]))
    end
    local argStr = table.concat(argTable, ", ")
    
    local target = (isSpam and not isSelf) and SpamFrame or Scroll
    local b = Instance.new("TextButton", target)
    b.Size = UDim2.new(1, 0, 0, 26)
    b.Text = (isSelf and "[S] " or "") .. name
    -- Фикс ZIndex: кнопка должна быть выше контейнера
    b.ZIndex = 12 
    
    -- Сохраняем дефолтный цвет для отмены выделения
    local defaultColor = isSelf and Color3.fromRGB(30, 60, 30) or (isSpam and Color3.fromRGB(70, 30, 30) or Color3.fromRGB(40, 40, 40))
    b.BackgroundColor3 = defaultColor
    b.TextColor3 = Color3.new(1, 1, 1)
    
    b.MouseButton1Click:Connect(function()
        -- Отменяем старое выделение
        if selectedData then 
            selectedData.btn.BackgroundColor3 = selectedData.color
        end
        
        -- Выделяем всю кнопку фиолетовым
        selectedData = {btn = b, color = defaultColor}
        b.BackgroundColor3 = Color3.fromRGB(150, 50, 255)
        
        -- Обновляем данные
        local fullPath = getSafePath(rem)
        Details.Text = "Path: " .. fullPath .. "\n\nArgs: " .. argStr .. "\n\nScript: " .. fullPath .. ":FireServer(" .. argStr .. ")"
    end)
end

CopyArgs.MouseButton1Click:Connect(function() setclipboard(Details.Text:match("Args: (.*)\n\nScript") or "") end)
CopyScript.MouseButton1Click:Connect(function() setclipboard(Details.Text:match("Script: (.*)") or "") end)

local mt = getrawmetatable(game)
local old = mt.__namecall
setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    if method == "FireServer" or method == "fireServer" then
        local args = {...}
        local isSelf = checkcaller()
        task.spawn(function() pcall(addLog, self, args, isSelf) end) -- Добавил pcall для стабильности
    end
    return old(self, ...)
end)
setreadonly(mt, true)
