-- ЛОГИКА СВОРАЧИВАНИЯ
MinBtn.MouseButton1Click:Connect(function()
    ContentFrame.Visible = not ContentFrame.Visible
    local isVis = ContentFrame.Visible
    
    -- Скрываем лишние кнопки в шапке при сворачивании
    ControlBtn.Visible = isVis; SelfBtn.Visible = isVis; Title.Visible = isVis
    if not isVis then AntiSpamBtn.Visible = false end
    if isVis and not controlMode then AntiSpamBtn.Visible = true end

    local targetSize = isVis and UDim2.new(0, 820, 0, 440) or UDim2.new(0, 150, 0, 35)
    Main:TweenSize(targetSize, "Out", "Quad", 0.15, true)
    MinBtn.Text = isVis and "_" or "+"
    if isVis then lastCount = -1 end
end)

-- ПЕРЕКЛЮЧАТЕЛЬ CONTROL
ControlBtn.MouseButton1Click:Connect(function() 
    controlMode = not controlMode
    fullClear()
    ControlBtn.Text = "CONTROL: "..(controlMode and "ON" or "OFF")
    ControlBtn.BackgroundColor3 = controlMode and Color3.fromRGB(150, 50, 255) or Color3.fromRGB(80, 80, 85)
    
    -- Показываем кнопку антиспама только если контроль ВЫКЛЮЧЕН
    AntiSpamBtn.Visible = not controlMode
    if controlMode then antiSpam = false; AntiSpamBtn.Text = "ANTI-SPAM: OFF" end
end)

AntiSpamBtn.MouseButton1Click:Connect(function()
    antiSpam = not antiSpam
    AntiSpamBtn.Text = "ANTI-SPAM: "..(antiSpam and "ON" or "OFF")
    AntiSpamBtn.BackgroundColor3 = antiSpam and Color3.fromRGB(180, 150, 40) or Color3.fromRGB(60, 60, 65)
end)

