-- УЛУЧШЕННЫЙ ПАРСЕР (Генерирует готовый к запуску код)
local function parseTable(t, depth)
    depth = depth or 0
    if type(t) ~= "table" or depth > 4 then 
        if type(t) == "string" then return '"'..t..'"' end
        return tostring(t) 
    end
    
    local result = "{"
    local isArray = true
    local count = 0
    
    for k, v in pairs(t) do
        count = count + 1
        if type(k) ~= "number" then isArray = false end
    end

    local i = 0
    for k, v in pairs(t) do
        i = i + 1
        if i > 15 then result = result .. "... " break end
        
        local val = parseTable(v, depth + 1)
        if isArray then
            result = result .. val
        else
            -- Формат ["Key"] = Value для избежания ошибок парсинга
            local key = type(k) == "string" and '["'..k..'"]' or "["..tostring(k).."]"
            result = result .. key .. " = " .. val
        end
        if i < count then result = result .. ", " end
    end
    
    return result .. "}"
end

