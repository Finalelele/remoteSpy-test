-- LOGIC
local MainMemory, PathFilter = {}, {}
local selfMode, controlMode = true, true

local function addLog(rem, args, isSelf, typeLabel)
    if not rem then return end
    local eventPath = "game." .. rem:GetFullName()
    local argStr = "{}" -- Упрощенный парсер для стабильности
    
    table.insert(MainMemory, 1, {
        name = rem.Name, type = typeLabel, 
        fullText = "Path: "..eventPath.."\nType: "..typeLabel.."\nSelf: "..tostring(isSelf),
        isSelf = isSelf
    })
    if #MainMemory > 50 then table.remove(MainMemory, 51) end
end

-- HOOK (Замени на свой рабочий хук, если этот не поддерживается твоим эксплойтом)
local mt = getrawmetatable(game); local old = mt.__namecall; setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    local m = getnamecallmethod(); local s = checkcaller()
    if m == "FireServer" or m == "InvokeServer" then task.spawn(addLog, self, {...}, s, m == "FireServer" and "FS" or "IS") end
    return old(self, ...)
end)
setreadonly(mt, true)

