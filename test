-- ПАРСЕР (Улучшен для таблиц)
local function parseTable(t, depth)
    depth = depth or 0
    if type(t) ~= "table" or depth > 3 then return tostring(t) end
    local result = "{"
    for k, v in pairs(t) do
        result = result .. tostring(k) .. "=" .. parseTable(v, depth + 1) .. ","
    end
    return result .. "}"
end

local function getSafePath(obj)
    local p = ""
    pcall(function()
        local t = obj
        while t and t ~= game do
            local n = tostring(t.Name); p = (n:match("[%s%W]") and '["'..n..'"]' or n) .. (p ~= "" and "." .. p or ""); t = t.Parent
        end
    end)
    return "game." .. p
end

local function addLog(rem, args, isSelf, typeLabel)
    if not rem then return end
    local eventPath = getSafePath(rem)
    local argStrings = {}
    for _, v in pairs(args) do table.insert(argStrings, parseTable(v)) end
    local finalArgs = table.concat(argStrings, ", ")
    
    local filterSig = controlMode and eventPath or (eventPath .. finalArgs)
    if not isSelf and PathFilter[filterSig] then return end
    if isSelf and not selfMode then return end

    PathFilter[filterSig] = true
    table.insert(MainMemory, 1, {
        guid = generateGUID(), name = tostring(rem.Name), type = typeLabel, 
        fullText = string.format("-- KRALLDEN SPY\nMethod: %s\nPath: %s\nArguments: %s", typeLabel, eventPath, finalArgs), 
        isSelf = isSelf
    })
    if #MainMemory > 100 then table.remove(MainMemory, 101) end
end

-- HOOK
local mt = getrawmetatable(game); local old = mt.__namecall; setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    local m = getnamecallmethod(); local a = {...}; local s = checkcaller()
    if m == "FireServer" then task.spawn(addLog, self, a, s, "FS")
    elseif m == "InvokeServer" then task.spawn(addLog, self, a, s, "IS") end
    return old(self, ...)
end)
setreadonly(mt, true)

