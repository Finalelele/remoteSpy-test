-- ЛОГИКА (БЕЗ WARN И С ФИЛЬТРОМ RELIABLE)
local loggedData = {}
local curArgs, curScript = "", ""

local function getSafePath(obj)
    local s, res = pcall(function() return obj:GetFullName() end)
    return s and res or "Unknown_Path"
end

local function formatVal(v)
    local t = typeof(v)
    if t == "table" then return "{table}"
    elseif t == "Instance" then return getSafePath(v)
    elseif t == "string" then return '"'..v..'"'
    else return tostring(v) end
end

local function addLog(rem, args)
    pcall(function()
        local name = rem.Name
        local argTable = {}
        for _, v in pairs(args) do table.insert(argTable, formatVal(v)) end
        local argStr = table.concat(argTable, ", ")
        
        -- 2. ФИЛЬТР RELIABLE (Исправлено)
        local key = name .. argStr
        if loggedData[key] then return end
        loggedData[key] = true

        local b = Instance.new("TextButton", Scroll)
        b.Size = UDim2.new(1, 0, 0, 25); b.Text = name
        b.BackgroundColor3 = Color3.fromRGB(45, 45, 45); b.TextColor3 = Color3.new(1, 1, 1)
        
        -- 3. ЗАЩИТА ОТ ЗАВИСАНИЙ (Исправлено)
        b.MouseButton1Click:Connect(function()
            pcall(function()
                local path = getSafePath(rem)
                curArgs = argStr
                curScript = "game." .. path .. ":FireServer(" .. argStr .. ")"
                Details.Text = "Path: " .. path .. "\n\nArgs: " .. argStr .. "\n\nScript: " .. curScript
            end)
        end)
    end)
end

CopyArgs.MouseButton1Click:Connect(function() setclipboard(curArgs) end)
CopyScript.MouseButton1Click:Connect(function() setclipboard(curScript) end)

local mt = getrawmetatable(game)
local old = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    if method == "FireServer" or method == "fireServer" then
        local args = {...}
        task.spawn(function() addLog(self, args) end)
    end
    return old(self, ...)
end)
setreadonly(mt, true)
