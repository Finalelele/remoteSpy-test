-- ЛОГИКА
local callCounts = {}
local lastTime = {}
local loggedKeys = {}
local blacklisted = {}
local currentScript = ""

local function safeFormat(v)
    local s, res = pcall(function()
        local t = typeof(v)
        if t == "string" then return '"'..v..'"'
        elseif t == "Instance" then return v:GetFullName()
        elseif t == "table" then return "{table}"
        else return tostring(v) end
    end)
    return s and res or "???"
end

local function addLog(rem, args)
    if not rem or not rem.Name then return end
    local name = rem.Name
    if blacklisted[name] then return end

    local argTable = {}
    for _, v in pairs(args) do table.insert(argTable, safeFormat(v)) end
    local argStr = table.concat(argTable, ", ")
    local key = name .. "|" .. argStr
    
    local now = tick()
    local isSpam = lastTime[name] and (now - lastTime[name] < 0.5)
    
    callCounts[name] = (callCounts[name] or 0) + 1
    lastTime[name] = now

    -- 1. Если это 11-й вызов — в бан навсегда
    if callCounts[name] > 10 then
        blacklisted[name] = true
        return
    end

    -- 2. Если аргументы те же — скипаем (чтобы не дублировать кнопки)
    if loggedKeys[key] then return end
    loggedKeys[key] = true

    -- 3. Выбираем список (обычный или боковой для спама)
    local targetScroll = isSpam and SpamFrame or Scroll
    
    local b = Instance.new("TextButton", targetScroll)
    b.Size = UDim2.new(1, 0, 0, 25)
    b.Text = name .. (isSpam and " [SPAM]" or "")
    b.BackgroundColor3 = isSpam and Color3.fromRGB(80, 40, 40) or Color3.fromRGB(50, 50, 50)
    b.TextColor3 = Color3.new(1, 1, 1)
    
    b.MouseButton1Click:Connect(function()
        pcall(function()
            local path = rem:GetFullName()
            currentScript = "game." .. path .. ":FireServer(" .. argStr .. ")"
            Details.Text = "Path: " .. path .. "\n\nArgs: " .. argStr .. "\n\nFull:\n" .. currentScript
        end)
    end)
end

CopyScript.MouseButton1Click:Connect(function() setclipboard(currentScript) end)

-- ХУК (Убрали проверку checkcaller)
local mt = getrawmetatable(game)
local old = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    if method == "FireServer" or method == "fireServer" then
        -- Теперь логируем ВСЁ, даже вызовы инжектора
        task.spawn(function() addLog(self, args) end)
    end
    return old(self, table.unpack(args))
end)
setreadonly(mt, true)
