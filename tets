-- ЛОГИКА
local callCounts, lastTime, loggedKeys, blacklisted = {}, {}, {}, {}
local curArgs, curScript = "", ""

-- Безопасное получение пути (фикс ошибки capability)
local function getSafePath(obj)
    local s, res = pcall(function() return obj:GetFullName() end)
    if s then return res end
    local s2, res2 = pcall(function() return obj.Name end)
    return s2 and ("Target: " .. res2) or "Unknown_Instance (No Access)"
end

local function safeFormat(v)
    local t = typeof(v)
    if t == "table" then return "{table}"
    elseif t == "Instance" then return getSafePath(v)
    elseif t == "string" then return '"'..v..'"'
    else return tostring(v) end
end

local function addLog(rem, args, isSelf)
    local success, err = pcall(function()
        if not rem then return end
        local name = (pcall(function() return rem.Name end) and rem.Name) or "UnknownRemote"
        if blacklisted[name] and not isSelf then return end

        local argTable = {}
        for _, v in pairs(args) do table.insert(argTable, safeFormat(v)) end
        local argStr = table.concat(argTable, ", ")
        local key = name .. "|" .. argStr
        
        local now = tick()
        local isSpam = lastTime[name] and (now - lastTime[name] < 0.5)
        
        if not isSelf then
            callCounts[name] = (callCounts[name] or 0) + 1
            lastTime[name] = now
            if callCounts[name] > 10 then blacklisted[name] = true; return end
            if loggedKeys[key] then return end
        end
        
        loggedKeys[key] = true
        local target = (isSpam and not isSelf) and SpamFrame or Scroll
        
        local b = Instance.new("TextButton", target)
        b.Size = UDim2.new(1, 0, 0, 25); b.Text = (isSelf and "[S] " or "") .. name
        b.BackgroundColor3 = isSelf and Color3.fromRGB(40, 70, 40) or (isSpam and Color3.fromRGB(80, 40, 40) or Color3.fromRGB(50, 50, 50))
        b.TextColor3 = Color3.new(1, 1, 1); b.ZIndex = 110
        
        b.MouseButton1Click:Connect(function()
            local path = getSafePath(rem)
            curArgs = argStr
            curScript = "game." .. path .. ":FireServer(" .. argStr .. ")"
            Details.Text = "Path: "..path.."\n\nArgs:\n"..argStr.."\n\nScript:\n"..curScript
        end)
    end)
end

CopyArgs.MouseButton1Click:Connect(function() setclipboard(curArgs) end)
CopyScript.MouseButton1Click:Connect(function() setclipboard(curScript) end)

local mt = getrawmetatable(game)
local old = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    if method == "FireServer" or method == "fireServer" then
        local isSelf = checkcaller()
        task.spawn(function() addLog(self, args, isSelf) end)
    end
    return old(self, table.unpack(args))
end)
setreadonly(mt, true)
